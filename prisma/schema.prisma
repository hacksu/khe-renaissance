// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  Application   Application[]

  pairAssignments  PairAssignment[]
  pairComparisons  PairComparison[]

  role       String?
  curve      Float   @default(0.0)
  judgeTrack String? // null = general judge, set = track-specific judge (track name)

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Invite {
  id        String   @id @default(uuid())
  email     String
  role      String
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  @@unique([email, role])
  @@map("invite")
}

model Application {
  id                 String   @id @default(uuid())
  firstName          String   @default("")
  lastName           String   @default("")
  age                Int      @default(18)
  phoneNumber        String   @default("")
  email              String   @default("")
  countryOfResidence String   @default("")
  school             String   @default("")
  levelOfStudy       String   @default("")
  fieldOfStudy       String   @default("")
  githubUrl          String   @default("")
  personalUrl        String   @default("")
  projectIdea        String   @default("")
  gender             String   @default("")
  pronouns           String   @default("")
  dietaryRestriction String   @default("")
  updatedAt          DateTime @default(now())

  submitted Boolean @default(false)
  approved  Boolean @default(false)
  checkedIn Boolean @default(false)

  mlhCodeOfConduct Boolean @default(false)
  mlhAuthorization Boolean @default(false)
  mlhEmails        Boolean @default(false)

  user   User   @relation(fields: [userId], references: [id])
  userId String

  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  @@unique([userId])
  @@map("application")
}

model Project {
  id          String  @id @default(uuid())
  name        String
  description String?
  tableNumber String?

  // Legacy track string (deprecated, use trackId relation)
  track   String @default("General")

  trackId String?
  Track   Track?  @relation(fields: [trackId], references: [id])

  members Application[]

  pairAssignmentsA PairAssignment[] @relation("PairAssignmentA")
  pairAssignmentsB PairAssignment[] @relation("PairAssignmentB")
  pairComparisonsA PairComparison[] @relation("PairComparisonA")
  pairComparisonsB PairComparison[] @relation("PairComparisonB")
  crowdBTStates    CrowdBTState[]

  @@map("project")
}

model Track {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  projects Project[]

  @@map("track")
}

model JudgingCriterion {
  id          String  @id @default(uuid())
  slug        String  @unique
  name        String
  description String?
  maxScore    Int     @default(5)
  weight      Float   @default(1.0)
  order       Int     @default(0)
  optional    Boolean @default(false)
  allowOptOut Boolean @default(false)

  pairResults   PairCriterionResult[]
  crowdBTStates CrowdBTState[]

  @@map("judging_criterion")
}

model Setting {
  key   String @id
  value String

  @@map("setting")
}

model ReminderSignup {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("reminder_signup")
}

model PairAssignment {
  id         String  @id @default(uuid())
  judgeId    String
  judge      User    @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  projectAId String
  projectA   Project @relation("PairAssignmentA", fields: [projectAId], references: [id], onDelete: Cascade)
  projectBId String
  projectB   Project @relation("PairAssignmentB", fields: [projectBId], references: [id], onDelete: Cascade)

  status     String  @default("assigned") // 'assigned', 'completed', 'skipped'
  skipReason String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@unique([judgeId, projectAId, projectBId])
  @@map("pair_assignment")
}

model PairComparison {
  id         String  @id @default(uuid())
  judgeId    String
  judge      User    @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  projectAId String
  projectA   Project @relation("PairComparisonA", fields: [projectAId], references: [id], onDelete: Cascade)
  projectBId String
  projectB   Project @relation("PairComparisonB", fields: [projectBId], references: [id], onDelete: Cascade)

  comment String

  results PairCriterionResult[]

  createdAt DateTime @default(now())

  @@map("pair_comparison")
}

model PairCriterionResult {
  id               String           @id @default(uuid())
  pairComparisonId String
  pairComparison   PairComparison   @relation(fields: [pairComparisonId], references: [id], onDelete: Cascade)
  criterionId      String
  criterion        JudgingCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  winner String // 'A' | 'B' | 'OPT_OUT_A' | 'OPT_OUT_B'

  @@unique([pairComparisonId, criterionId])
  @@map("pair_criterion_result")
}

model CrowdBTState {
  id          String           @id @default(uuid())
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  criterionId String
  criterion   JudgingCriterion @relation(fields: [criterionId], references: [id], onDelete: Cascade)

  alpha           Float @default(1.0)
  beta            Float @default(1.0)
  comparisonCount Int   @default(0)

  @@unique([projectId, criterionId])
  @@map("crowd_bt_state")
}
